{
  "name": "xavicabot/filament-appointments",
  "description": "FilamentPHP 3 Appointment Picker (Tucalendi-style) + Admin resources + Google Calendar availability sync",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "filament/filament": "^3.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "google/apiclient": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "XaviCabot\\FilamentAppointments\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "XaviCabot\\FilamentAppointments\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "extra": {
    "laravel": {
      "providers": [
        "XaviCabot\\FilamentAppointments\\FilamentAppointmentsServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
